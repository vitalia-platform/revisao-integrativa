# mas os padrões mais comuns estão listados aqui como proteção.
exportacao/
amostra/
lotes/
saida/
fichamentos/

# Arquivos binários de pesquisa
*.pdf
*.PDF

# Arquivos de sistema
.DS_Store
__pycache__/
*.pyc
