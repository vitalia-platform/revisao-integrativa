# Contexto de sessão da IA (repositório aninhado isolado — configurado via install.sh)
.agent/session/
.agent/session/*

# criteria_config.yaml gerado pelo /integrative-review (específico de cada revisão)
criteria_config.yaml

# Dados de trabalho reais (pertencem ao repositório de cada revisão, não ao template)
