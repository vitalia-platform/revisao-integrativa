# ==============================================================================
# .env.example — Variáveis de Ambiente do Pipeline Vitalia
# ==============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores no .env com as suas credenciais reais.
#   3. NUNCA commite o .env — ele está no .gitignore.
#   4. O .env.example é seguro para commit e serve como documentação.
# ==============================================================================

# ── SERVIDOR OLLAMA ────────────────────────────────────────────────────────────
# URL base do seu servidor Ollama local ou em rede local.
# Exemplos:
#   http://localhost:11434        → Ollama rodando na mesma máquina
#   http://192.168.0.X:11434     → Ollama em outro computador da rede local
#   http://meu-servidor:11434    → Ollama com hostname configurado
OLLAMA_BASE_URL=http://localhost:11434

# ── API UNPAYWALL (Download de PDFs) ──────────────────────────────────────────
# E-mail para identificação na API Unpaywall (obrigatório para uso em produção).
# A Unpaywall usa o e-mail para rate limiting e contato em caso de abuso.
# Sem e-mail, as requisições podem ser rejeitadas.
# Cadastro: https://unpaywall.org/products/api
UNPAYWALL_EMAIL=seu-email@instituicao.edu.br
